generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  VISITOR
}

enum ExpressionOfInterest {
  YES
  NO
  MAYBE
}

enum VisitorStatus {
  NEW
  PENDING
  OVERDUE
  INTERESTED
  MAYBE_LATER
  JOINED
  REJECTED
  CATEGORY_CLASH
  CLOSED
}

model User {
  id           String     @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole @default(VISITOR)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignedVisitors Visitor[]   @relation("AssignedTo")
  createdFollowUps FollowUp[]  @relation("CreatedBy")

  @@index([role])
}

model Visitor {
  id               String     @id @default(uuid())
  name             String
  dateOfVisit      DateTime
  category         String
  mobileNo         String
  emailAddress     String?
  eoi              ExpressionOfInterest
  invitedBy        String?
  categoryClash    Boolean              @default(false)
  status           VisitorStatus        @default(NEW)

  assignedToId     String?
  assignedTo       User?                @relation("AssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)

  followUps        FollowUp[]

  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([status])
  @@index([assignedToId])
  @@index([dateOfVisit])
  @@index([mobileNo])
  @@index([emailAddress])
}

model FollowUp {
  id                String     @id @default(uuid())
  visitorId         String
  visitor           Visitor    @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  byId              String?
  by                User?      @relation("CreatedBy", fields: [byId], references: [id], onDelete: SetNull)

  date              DateTime
  feedback          String
  nextFollowUpDate  DateTime?
  status            VisitorStatus

  createdAt         DateTime   @default(now())

  @@index([visitorId])
  @@index([byId])
  @@index([status])
  @@index([nextFollowUpDate])
}